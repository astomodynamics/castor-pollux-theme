      "settings": {
        "foreground": "#90d8ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e8f2fa",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e8f2fa",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#a0e8ff"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#a0d0f0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#d0e4f4"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#6888a8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#a0d0f0"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#d0b8f0"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#f08080",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#e0d090",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#6888a8"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#a0f0d0"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ffa0a0"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#f0e0a0"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#f08080"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#90d8ff"
      }
    }
  ]
