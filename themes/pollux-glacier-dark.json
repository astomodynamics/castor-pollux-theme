  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6888a8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#a0e8ff"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#a0f0d0"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#d0b8f0"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#d0b8f0"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e8f2fa"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#ffa0a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#d0e4f4"
      }
    },
    {
