  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#2e6880", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#40E8A8" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#F0C040" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#C868E0" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#C868E0" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#E090F0" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#e4ecf0" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#F04848", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#F8D060" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#F0C040" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#00D48C", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#00A870", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#00D48C", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#00D48C" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#00A870", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#00C0D8" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#00D48C" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#b0c4d4" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#3898E0" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#F0C040" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#F0C040", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#00D48C", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#00D48C" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#F04848" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#3898E0" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#00D48C", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#40E8A8" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#3898E0", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#00C0D8" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#C868E0" } },
    { "scope": ["invalid"], "settings": { "foreground": "#F04848", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#40E8A8" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#F87070" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#F8D060" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#3e6880" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#3e6880" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#b0c4d4" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#3898E0" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#00A870", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#b8ccd8" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#F0C040",
    "class": "#F0C040",
    "interface": { "foreground": "#F0C040", "italic": true },
    "enum": "#F0C040",
    "enumMember": "#F0C040",
    "function": "#3898E0",
    "method": "#3898E0",
    "property": "#b0c4d4",
    "variable": "#e4ecf0",
    "variable.readonly": "#F0C040",
    "parameter": "#F8D060",
    "namespace": "#F0C040",
    "decorator": "#00A870"
  }
}