  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#8a7a9a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#e8c8f0"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#90e8b0"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#f080a0"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#f080a0"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#ebe6f0"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#f080a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ddd5e8"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#b87dd9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#b87dd9"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#d4a5f0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#80d8e0"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#90b8f0"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#f0d890"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#90e8b0"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#d4a5f0"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#c890e5"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#8a7a9a"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#b87dd9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#ebe6f0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#ebe6f0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#e8c8f0"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#70a0e0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#d4a5f0"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#8a7a9a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#60c8d0"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#f080a0"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#e06080",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#e0c070",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#8a7a9a"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#90e8b0"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#f080a0"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#f0d890"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#e06080"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#b87dd9"
      }
    }
  ]
}
