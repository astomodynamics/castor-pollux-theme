  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#4C6880", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#78A858" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#D8A840" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#B84848" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#B84848" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#D06868" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#E4DCD0" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#B84848", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#D8A840" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#D09038" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#D09038", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#B07028", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#D09038", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#D09038" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#B07028", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#7CA0C0" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#D09038" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#B8B0A4" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#58B890" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#D8A840" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#D8A840", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#78A858", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#D09038" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#B84848" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#5C84A0" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#D09038", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#90C070" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#5C84A0", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#58B890" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#B84848" } },
    { "scope": ["invalid"], "settings": { "foreground": "#B84848", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#90C070" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#D06868" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#E0A848" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#586C80" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#586C80" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#B8B0A4" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#5C84A0" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#B07028", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#C4BCB0" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#D8A840",
    "class": "#D8A840",
    "interface": { "foreground": "#D8A840", "italic": true },
    "enum": "#D8A840",
    "enumMember": "#D09038",
    "function": "#58B890",
    "method": "#58B890",
    "property": "#B8B0A4",
    "variable": "#E4DCD0",
    "variable.readonly": "#D09038",
    "parameter": "#D8A840",
    "namespace": "#D8A840",
    "decorator": "#B07028"
  }
}