  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#507080", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#98C040" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#F8C040" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#D03828" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#D03828" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#E85848" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#F2ECE0" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#D03828", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#E0C030" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#E8A820" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#E8A820", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#C89018", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#E8A820", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#E8A820" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#C89018", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#78A0C8" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#E8A820" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#D0C8B8" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#50B858" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#E0C030" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#E0C030", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#50B858", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#E8A820" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#D03828" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#5880A8" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#E8A820", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#68D870" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#5880A8", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#48A878" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#D03828" } },
    { "scope": ["invalid"], "settings": { "foreground": "#D03828", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#68D870" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#E85848" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#F8C040" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#607888" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#607888" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#D0C8B8" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#5880A8" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#C89018", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#D8D0C4" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#E0C030",
    "class": "#E0C030",
    "interface": { "foreground": "#E0C030", "italic": true },
    "enum": "#E0C030",
    "enumMember": "#E8A820",
    "function": "#50B858",
    "method": "#50B858",
    "property": "#D0C8B8",
    "variable": "#F2ECE0",
    "variable.readonly": "#E8A820",
    "parameter": "#E0C030",
    "namespace": "#E0C030",
    "decorator": "#C89018"
  }
}