  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#588098",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#60f0b8"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#60e0ff"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#c0a0f0"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#c0a0f0"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e0f0f8"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#ff80a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#c8e0f0"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
