        "foreground": "#60b8e0"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#60e0ff"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#40d8a0"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#60f0b8"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#60e0ff"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#00a0d8"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#588098"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#40c8f0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e0f0f8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e0f0f8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#60f0b8"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#60b8e0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#c8e0f0"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#588098",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#60b8e0"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#c0a0f0"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#f06080",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#e8c860",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#588098"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#60f0b8"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ff80a0"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#f8d870"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#f06080"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#40c8f0"
      }
    }
  ]
