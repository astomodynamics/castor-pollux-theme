  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6f6f6f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#82cfff"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#6fdc8c"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#be95ff"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#be95ff"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#f4f4f4"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#ff8389",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#fddc69"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#78a9ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#78a9ff"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#fa4d56",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#33b1ff"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#78a9ff"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#f1c21b"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#42be65"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#33b1ff"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#fa4d56"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#6f6f6f"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#0f62fe",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#f4f4f4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#f4f4f4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#82cfff"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#78a9ff",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#a8a8a8"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#6f6f6f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#33b1ff"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#be95ff"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#fa4d56",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#f1c21b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#6f6f6f"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#6fdc8c"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ff8389"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#fddc69"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#fa4d56"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#78a9ff"
      }
    }
  ]
}
