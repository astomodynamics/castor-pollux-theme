  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7a9a85",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#b8e8c8"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#70d8c8"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#d8a0d8"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#d8a0d8"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e0f0e6"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#f08090",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#e8d890"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#4dbd6a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#4dbd6a"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#7dd99a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#d9c070"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#80b8e0"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#e8d890"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#70d8c8"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#7dd99a"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#5dcd7a"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#7a9a85"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#4dbd6a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e0f0e6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e0f0e6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#b8e8c8"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#60a0d0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#7dd99a"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#7a9a85",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#50c0b0"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#d8a0d8"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#e06070",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#d9c070",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#7a9a85"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#7dd99a"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#f08090"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#e8d890"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#e06070"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#4dbd6a"
      }
    }
  ]
}
