      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#f098b0"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#f0c080"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#e07090"
      }
