  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7080a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#f0c080"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#e0a050"
      }
    },
    {
