  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#8a7a70",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#ffd9a8"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#9dea9f"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#ffb380"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#ffb380"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#f0e6e0"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#ff7777",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#e8dcd5"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#ff6b3d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#ff6b3d"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#ff9857",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#d68fd6"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#ffcc57"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#7dce82"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#9dea9f"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#ffd9a8"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#ff8a5e"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#8a7a70"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#ff6b3d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#f0e6e0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#f0e6e0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#ffd9a8"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#6eb3f7",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#ff9857"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#8a7a70",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#5fcfcf"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#ffb380"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff5555",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#ffcc57",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#8a7a70"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#9dea9f"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ff7777"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#ffd97a"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#ff5555"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#ff6b3d"
      }
    }
  ]
}
