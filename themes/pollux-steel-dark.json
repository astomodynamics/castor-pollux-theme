  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#687490",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#80b090"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#78a8b8"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#a090b8"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#a090b8"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#d8dce8"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#d08080",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#b8c0d4"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
