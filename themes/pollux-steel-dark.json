      "settings": {
        "foreground": "#7090c0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#d8dce8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#d8dce8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#80b090"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#8090b0",
        "fontStyle": "underline"
      }
