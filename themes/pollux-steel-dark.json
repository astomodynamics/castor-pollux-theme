      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#a090b8"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#c06060",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#b0a060",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#687490"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#80b090"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#d08080"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#c0b070"
      }
