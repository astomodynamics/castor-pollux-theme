      "settings": {
        "foreground": "#00d9a0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e8eef5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e8eef5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#a8f0d8"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#60a0ff",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#ff6b9d"
      }
    },
    {
