  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7a8899",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#a8f0d8"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#40e8e8"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#ff8fb8"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#ff8fb8"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e8eef5"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#ff6b9d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ffe080"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
