      "settings": {
        "foreground": "#7a8899",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#00d0d0"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#ff8fb8"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff6b9d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#ffd060",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#7a8899"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#40f0c0"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ff8fb8"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#ffe080"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#ff6b9d"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#d080ff"
      }
    }
  ]
