  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5a6f85",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#80deea"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#b9f6ca"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#c5d3e8"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#ff8a80",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ffe57f"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#4fc3f7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#4fc3f7"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#ef5350",
