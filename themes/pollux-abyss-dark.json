      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#81d4fa"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#81d4fa"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#ffd740"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#69f0ae"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#4fc3f7"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#ef5350"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#5a6f85"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#29b6f6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#c5d3e8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#c5d3e8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#80deea"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#4fc3f7",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#7a90a8"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#5a6f85",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#80deea"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ef5350",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#ffd740",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#5a6f85"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#b9f6ca"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ff8a80"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#ffe57f"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#ef5350"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#4fc3f7"
      }
    }
  ]
}
