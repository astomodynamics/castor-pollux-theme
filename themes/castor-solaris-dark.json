  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#3a6090", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#2ECC40" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#FFAA40" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#E040A0" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#E040A0" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#F070C0" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#e8ecf4" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#FF4136", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#FFAA40" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#FF8C00" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#FF8C00", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#cc7000", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#FF8C00", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#FF8C00" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#cc7000", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#20C4D4" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#FF8C00" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#b8c4d8" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#2EA4FF" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#FFAA40" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#FFAA40", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#2ECC40", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#FF8C00" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#FF4136" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#2EA4FF" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#FF8C00", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#2ECC40" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#2EA4FF", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#20C4D4" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#E040A0" } },
    { "scope": ["invalid"], "settings": { "foreground": "#FF4136", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#5EE070" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#FF6B60" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#FFAA40" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#4a6888" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#4a6888" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#b8c4d8" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#2EA4FF" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#cc7000", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#c8d0e0" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#FFAA40",
    "class": "#FFAA40",
    "interface": { "foreground": "#FFAA40", "italic": true },
    "enum": "#FFAA40",
    "enumMember": "#FF8C00",
    "function": "#2EA4FF",
    "method": "#2EA4FF",
    "property": "#b8c4d8",
    "variable": "#e8ecf4",
    "variable.readonly": "#FF8C00",
    "parameter": "#FFAA40",
    "namespace": "#FFAA40",
    "decorator": "#cc7000"
  }
}