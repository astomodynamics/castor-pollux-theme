  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#4A6878", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#8AAC48" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#E0A038" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#CC5848" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#CC5848" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#E87060" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#F0E8DC" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#CC5848", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#E8B830" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#E0A038" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#E07828", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#C06820", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#E07828", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#E07828" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#C06820", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#C8A050" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#E0A038" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#C8C0B0" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#C8A050" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#E8B830" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#E8B830", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#8AAC48", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#E07828" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#CC5848" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#608AAC" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#E07828", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#A0C860" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#608AAC", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#58A880" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#CC5848" } },
    { "scope": ["invalid"], "settings": { "foreground": "#CC5848", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#A0C860" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#E87060" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#F0B850" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#5A7888" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#5A7888" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#C8C0B0" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#608AAC" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#C06820", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#D0C8BC" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#E8B830",
    "class": "#E8B830",
    "interface": { "foreground": "#E8B830", "italic": true },
    "enum": "#E8B830",
    "enumMember": "#E0A038",
    "function": "#C8A050",
    "method": "#C8A050",
    "property": "#C8C0B0",
    "variable": "#F0E8DC",
    "variable.readonly": "#E0A038",
    "parameter": "#E8B830",
    "namespace": "#E8B830",
    "decorator": "#C06820"
  }
}