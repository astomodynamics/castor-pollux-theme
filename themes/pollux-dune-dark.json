  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5e5040", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#8aad7a" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#c8a848" }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#a87898" }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": { "foreground": "#a87898" }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#c498b4" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#d8d0c0" }
    },
    {
      "scope": ["variable.language"],
      "settings": { "foreground": "#c87850", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#dcc060" }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": { "foreground": "#c8a848" }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": { "foreground": "#c87850", "fontStyle": "italic" }
    },
    {
      "scope": ["storage.modifier"],
      "settings": { "foreground": "#a06040", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword.control"],
      "settings": { "foreground": "#c87850", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"],
      "settings": { "foreground": "#c87850" }
    },
    {
      "scope": ["keyword.control.conditional", "keyword.control.loop"],
      "settings": { "foreground": "#a06040", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#c8a848" }
    },
    {
      "scope": ["keyword.operator.logical", "keyword.operator.comparison"],
      "settings": { "foreground": "#c87850" }
    },
    {
      "scope": ["variable.other.member", "variable.other.property"],
      "settings": { "foreground": "#b8b0a0" }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": { "foreground": "#70a898" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#c8a848" }
    },
    {
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#c8a848", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#8aad7a", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#c87850" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#cc5544" }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#6890b0" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#c87850", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#8aad7a" }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#6890b0", "fontStyle": "underline" }
    },
    {
      "scope": ["support.variable"],
      "settings": { "foreground": "#70a898" }
    },
    {
      "scope": ["support.constant"],
      "settings": { "foreground": "#a87898" }
    },
    {
      "scope": ["invalid"],
      "settings": { "foreground": "#cc5544", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#a8c898" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#e07060" }
    },
    {
      "scope": ["markup.changed"],
      "settings": { "foreground": "#dcc060" }
    },
    {
      "scope": ["punctuation.definition", "punctuation.terminator"],
      "settings": { "foreground": "#706050" }
    },
    {
      "scope": ["punctuation.separator", "punctuation.separator.comma"],
      "settings": { "foreground": "#706050" }
    },
    {
      "scope": ["meta.object-literal.key"],
      "settings": { "foreground": "#b8b0a0" }
    },
    {
      "scope": ["source.json support.type.property-name"],
      "settings": { "foreground": "#c8a848" }
    },
    {
      "scope": ["meta.decorator", "meta.decorator entity.name.function"],
      "settings": { "foreground": "#a06040", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.other.readwrite", "variable.other.object"],
      "settings": { "foreground": "#c4bca8" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#c8a848",
    "class": "#c8a848",
    "interface": { "foreground": "#c8a848", "italic": true },
    "enum": "#c8a848",
    "enumMember": "#c8a848",
    "function": "#70a898",
    "method": "#70a898",
    "property": "#b8b0a0",
    "variable": "#d8d0c0",
    "variable.readonly": "#c8a848",
    "parameter": "#dcc060",
    "namespace": "#c8a848",
    "decorator": "#a06040"
  }
}