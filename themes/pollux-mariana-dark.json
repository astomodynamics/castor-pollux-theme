        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#fff080"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#5888b0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#00d8e8"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#d080ff"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff5089",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#ffe040",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#5888b0"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#40ffd8"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ff78a8"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#fff080"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#ff5089"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#b040ff"
      }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.scope-resolution"],
      "settings": {
        "foreground": "#d080ff"
      }
    },
    {
      "scope": ["punctuation.separator.namespace", "punctuation.separator.scope-resolution"],
      "settings": {
        "foreground": "#40c8ff"
      }
    },
    {
      "scope": ["meta.preprocessor", "entity.name.function.preprocessor"],
      "settings": {
        "foreground": "#b040ff"
      }
    },
    {
      "scope": ["variable.other.readwrite", "variable.other.object"],
      "settings": {
        "foreground": "#b8d0e8"
      }
    },
    {
      "scope": ["punctuation.definition", "punctuation.terminator"],
      "settings": {
        "foreground": "#80a0c0"
      }
    }
