      "settings": {
        "foreground": "#ff78a8"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#00b0ff"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#b040ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e0eaf5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e0eaf5",
        "fontStyle": "bold"
      }
