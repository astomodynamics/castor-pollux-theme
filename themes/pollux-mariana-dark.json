  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5888b0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#40ffd8"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#ffe040"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#d080ff"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#d080ff"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e0eaf5"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#ff5089",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ffb060"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
