  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#506880", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#88B878" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#D89040" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#C86868" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#C86868" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#D88888" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#E8E0D4" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#C86868", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#D89040" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#D89040" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#C07838", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#A86830", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#C07838", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#C07838" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#A86830", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#78A8C8" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#C07838" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#B8B0A4" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#58A890" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#D89040" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#D89040", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#80B070", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#C07838" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#C86868" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#5888A8" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#C07838", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#98C888" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#5888A8", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#58A890" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#C86868" } },
    { "scope": ["invalid"], "settings": { "foreground": "#C86868", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#98C888" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#D88888" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#D89040" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#587080" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#587080" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#B8B0A4" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#5888A8" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#A86830", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#C8C0B4" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#D89040",
    "class": "#D89040",
    "interface": { "foreground": "#D89040", "italic": true },
    "enum": "#D89040",
    "enumMember": "#D89040",
    "function": "#58A890",
    "method": "#58A890",
    "property": "#B8B0A4",
    "variable": "#E8E0D4",
    "variable.readonly": "#D89040",
    "parameter": "#D89040",
    "namespace": "#D89040",
    "decorator": "#A86830"
  }
}