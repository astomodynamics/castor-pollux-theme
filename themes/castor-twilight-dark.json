  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7068a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#90d8b0"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#80b0d8"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#e0c080"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#f0d090"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e4e0f4"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#e89090",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ccc4e4"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#a090d8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#a090d8"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#b898d8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#9888d0"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#80a0e8"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#70c8a0"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#90d8b0"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#80b0d8"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#6080d0"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#7068a0"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#a090d8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e4e0f4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e4e0f4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#90d8b0"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#9888d0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#ccc4e4"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#7068a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#9888d0"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#e0c080"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#d87070",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#e0c080",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#7068a0"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#90d8b0"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#e89090"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#f0d090"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#d87070"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#a090d8"
      }
    }
  ]
}
