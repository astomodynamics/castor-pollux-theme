  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#3A6898", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#7BC91F" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#FFD00A" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#EC0048" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#EC0048" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#FF1D62" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#F2F2F2" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#E1321A", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#FFD00A" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#FFC005" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#FFC005", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#CC9800", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#FFC005", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#FFC005" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#CC9800", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#2AA7E7" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#FFC005" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#C0C8D8" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#2AA7E7" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#FFD00A" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#FFD00A", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#6AB017", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#FFC005" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#E1321A" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#729FCF" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#FFC005", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#7BC91F" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#729FCF", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#2AA7E7" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#EC0048" } },
    { "scope": ["invalid"], "settings": { "foreground": "#E1321A", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#7BC91F" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#FF361E" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#FFD00A" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#4A6A90" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#4A6A90" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#C0C8D8" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#729FCF" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#CC9800", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#D0D8E4" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#FFD00A",
    "class": "#FFD00A",
    "interface": { "foreground": "#FFD00A", "italic": true },
    "enum": "#FFD00A",
    "enumMember": "#FFC005",
    "function": "#2AA7E7",
    "method": "#2AA7E7",
    "property": "#C0C8D8",
    "variable": "#F2F2F2",
    "variable.readonly": "#FFC005",
    "parameter": "#FFD00A",
    "namespace": "#FFD00A",
    "decorator": "#CC9800"
  }
}