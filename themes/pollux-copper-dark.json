  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#8a7a70",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#f0c8a0"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#90d890"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#c8a0c8"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#c8a0c8"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#f0e8e4"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#e87070",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#e8dcd5"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#d08050",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#d08050"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#e8a070",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#70c8c8"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#80a8d8"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#e8c870"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#90d890"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#e8a070"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#e09060"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#8a7a70"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#d08050",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#f0e8e4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#f0e8e4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#f0c8a0"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#6090c0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#e8a070"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#8a7a70",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#50b0b0"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#c8a0c8"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#d85050",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#d8b050",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#8a7a70"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#90d890"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#e87070"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#e8c870"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#d85050"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#d08050"
      }
    }
  ]
}
