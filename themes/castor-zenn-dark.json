      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#38bdf8"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#4ade80"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#f43f5e"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#64748b"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#3b82f6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e2e8f0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e2e8f0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#a5f3fc"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#38bdf8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#94a3b8"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#64748b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#f43f5e",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#64748b"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#4ade80"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#fb7185"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#fcd34d"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#f43f5e"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#06b6d4"
      }
    }
  ]
}
