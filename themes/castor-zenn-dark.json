  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#64748b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#a5f3fc"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#4ade80"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e2e8f0"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#fb7185",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#fcd34d"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#06b6d4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
