  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#546878", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#80A050" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#E89838" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#C84040" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#C84040" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#E06060" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#F0E4D4" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#C84040", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#D88020" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#D88020" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#E06820", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#C04818", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#E06820", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#E06820" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#C04818", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#8098B8" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#D88020" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#C0B8A4" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#B89838" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#D88020" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#D88020", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#80A050", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#E06820" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#C84040" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#607898" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#E06820", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#98B868" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#607898", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#509878" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#C84040" } },
    { "scope": ["invalid"], "settings": { "foreground": "#C84040", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#98B868" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#E06060" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#E89838" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#607080" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#607080" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#C0B8A4" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#607898" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#C04818", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#CCC4B0" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#D88020",
    "class": "#D88020",
    "interface": { "foreground": "#D88020", "italic": true },
    "enum": "#D88020",
    "enumMember": "#D88020",
    "function": "#B89838",
    "method": "#B89838",
    "property": "#C0B8A4",
    "variable": "#F0E4D4",
    "variable.readonly": "#D88020",
    "parameter": "#D88020",
    "namespace": "#D88020",
    "decorator": "#C04818"
  }
}