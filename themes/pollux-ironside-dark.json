  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#305868", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#40C870" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#F09050" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#B860C8" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#B860C8" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#D080E0" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#E0E8EC" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#E04840", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#F09050" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#E07030" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#E07030", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#B85820", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#E07030", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#E07030" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#B85820", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#30B8C8" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#E07030" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#A8B8C4" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#30B8C8" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#F09050" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#F09050", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#40C870", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#E07030" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#E04840" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#3890D0" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#E07030", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#40C870" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#3890D0", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#30B8C8" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#B860C8" } },
    { "scope": ["invalid"], "settings": { "foreground": "#E04840", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#68E090" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#F07068" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#F09050" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#486878" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#486878" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#A8B8C4" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#30B8C8" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#B85820", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#B8C8D0" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#F09050",
    "class": "#F09050",
    "interface": { "foreground": "#F09050", "italic": true },
    "enum": "#F09050",
    "enumMember": "#E07030",
    "function": "#30B8C8",
    "method": "#30B8C8",
    "property": "#A8B8C4",
    "variable": "#E0E8EC",
    "variable.readonly": "#E07030",
    "parameter": "#F09050",
    "namespace": "#F09050",
    "decorator": "#B85820"
  }
}