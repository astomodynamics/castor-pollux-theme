  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#384088", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#48E880" } },
    { "scope": ["string.regexp"], "settings": { "foreground": "#FFE440" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#D050FF" } },
    { "scope": ["constant.character", "constant.other"], "settings": { "foreground": "#D050FF" } },
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#E080FF" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#E8E4F4" } },
    { "scope": ["variable.language"], "settings": { "foreground": "#FF2D78", "fontStyle": "italic" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#FFE440" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#FFD600" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#FFD600", "fontStyle": "italic" } },
    { "scope": ["storage.modifier"], "settings": { "foreground": "#CCA800", "fontStyle": "italic" } },
    { "scope": ["keyword.control"], "settings": { "foreground": "#FFD600", "fontStyle": "italic" } },
    { "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"], "settings": { "foreground": "#FFD600" } },
    { "scope": ["keyword.control.conditional", "keyword.control.loop"], "settings": { "foreground": "#CCA800", "fontStyle": "italic" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#00D4F0" } },
    { "scope": ["keyword.operator.logical", "keyword.operator.comparison"], "settings": { "foreground": "#FFD600" } },
    { "scope": ["variable.other.member", "variable.other.property"], "settings": { "foreground": "#b8b4d0" } },
    { "scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": { "foreground": "#4488FF" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": { "foreground": "#FFE440" } },
    { "scope": ["entity.name.type.interface"], "settings": { "foreground": "#FFE440", "fontStyle": "italic" } },
    { "scope": ["entity.other.inherited-class"], "settings": { "foreground": "#48E880", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#FFD600" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#FF2D78" } },
    { "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#4488FF" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#FFD600", "fontStyle": "bold" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#48E880" } },
    { "scope": ["markup.underline.link"], "settings": { "foreground": "#4488FF", "fontStyle": "underline" } },
    { "scope": ["support.variable"], "settings": { "foreground": "#00D4F0" } },
    { "scope": ["support.constant"], "settings": { "foreground": "#D050FF" } },
    { "scope": ["invalid"], "settings": { "foreground": "#FF2D78", "fontStyle": "bold" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#78F0A0" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#FF5898" } },
    { "scope": ["markup.changed"], "settings": { "foreground": "#FFE440" } },
    { "scope": ["punctuation.definition", "punctuation.terminator"], "settings": { "foreground": "#484880" } },
    { "scope": ["punctuation.separator", "punctuation.separator.comma"], "settings": { "foreground": "#484880" } },
    { "scope": ["meta.object-literal.key"], "settings": { "foreground": "#b8b4d0" } },
    { "scope": ["source.json support.type.property-name"], "settings": { "foreground": "#4488FF" } },
    { "scope": ["meta.decorator", "meta.decorator entity.name.function"], "settings": { "foreground": "#CCA800", "fontStyle": "italic" } },
    { "scope": ["variable.other.readwrite", "variable.other.object"], "settings": { "foreground": "#c8c4dc" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#FFE440",
    "class": "#FFE440",
    "interface": { "foreground": "#FFE440", "italic": true },
    "enum": "#FFE440",
    "enumMember": "#FFD600",
    "function": "#4488FF",
    "method": "#4488FF",
    "property": "#b8b4d0",
    "variable": "#E8E4F4",
    "variable.readonly": "#FFD600",
    "parameter": "#FFE440",
    "namespace": "#FFE440",
    "decorator": "#CCA800"
  }
}