  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6e7681",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#7ee787"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#bc8cff"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#bc8cff"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#c9d1d9"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#ffa198",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#f3e5ab"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#79c0ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#ff7b72",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#58a6ff"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#d2a8ff"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#e3b341"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#7ee787"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#6e7681"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#1f6feb",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#c9d1d9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#c9d1d9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#58a6ff",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#8b949e"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#6e7681",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#bc8cff"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff7b72",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#e3b341",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#6e7681"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#a5d6a7"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ffa198"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#f3e5ab"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#79c0ff"
      }
    }
  ]
}
