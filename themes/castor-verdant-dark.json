  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5c806e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#a8d8b9"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#49c5b6"
      }
    },
    {
