  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#505050",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#88e5ff"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#66ffaa"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#cc66ff"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#cc66ff"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#ff6699",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ffdd55"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#00d4ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#00d4ff"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#ff3366",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#55e5ff"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#55ccee"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#ffcc00"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#00ff88"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#00d4ff"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#ff3366"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#505050"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#00a8cc",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#d4d4d4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#d4d4d4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#88e5ff"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#00d4ff",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#505050",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#55e5ff"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#cc66ff"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff3366",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#ffcc00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#505050"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#66ffaa"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#ff6699"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#ffdd55"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#ff3366"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#00d4ff"
      }
    }
  ]
}
