  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5a7090",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#90c0e0"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#60d0a0"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#a090d0"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#a090d0"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e4ecf7"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#f07090",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#c5d4e8"
      }
    },
    {
      "scope": ["keyword", "storage.type"],
      "settings": {
        "foreground": "#4080e0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#4080e0"
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#8090cc",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#5c8fcc"
      }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#70b0e0"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#40c0c0"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#40c090"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#60d0a0"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#5c8fcc"
      }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#5a7090"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#4080e0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e4ecf7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e4ecf7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#90c0e0"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#5c8fcc",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#c5d4e8"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#5a7090",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.variable"],
      "settings": {
        "foreground": "#5c8fcc"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#a090d0"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#e05070",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#d0a050",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#5a7090"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#60d0a0"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#f07090"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#e0b060"
      }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": {
        "foreground": "#e05070"
      }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": {
        "foreground": "#4080e0"
      }
    }
  ]
}
