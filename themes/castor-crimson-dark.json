    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#d890c8"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff6080",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#d8b060",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#8a7078"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#80d8a0"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#e86080"
