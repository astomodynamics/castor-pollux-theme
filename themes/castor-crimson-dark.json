  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#8a7078",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#f0b8c8"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#80d8a0"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#d890c8"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#d890c8"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#f0e6ea"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#e86080",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#e8d8dd"
      }
    },
    {
